#!/usr/bin/env bash
# Pre-commit hook: block commits that include secret credential files, then
# run the existing migration-validation check.
#
# Guarded paths:
#   *.keystore                        — Android signing keystores
#   android/app/google-services.json  — Firebase Android credentials
#   ios/App/GoogleService-Info.plist  — Firebase iOS credentials

BLOCKED_PATTERNS=(
  "\.keystore$"
  "^android/app/google-services\.json$"
  "^ios/App/GoogleService-Info\.plist$"
)

# --diff-filter=ACMR: only Added, Copied, Modified, Renamed files.
# Deletions are intentionally excluded so developers can run
# `git rm --cached <secret-file>` to remove tracked secrets without the
# hook blocking that remediation commit.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
FOUND=()

for pattern in "${BLOCKED_PATTERNS[@]}"; do
  while IFS= read -r match; do
    [[ -n "$match" ]] && FOUND+=("$match")
  done < <(echo "$STAGED_FILES" | grep -E "$pattern" || true)
done

if [[ ${#FOUND[@]} -gt 0 ]]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║           COMMIT BLOCKED — SECRET FILE DETECTED             ║"
  echo "╠══════════════════════════════════════════════════════════════╣"
  echo "║                                                              ║"
  echo "║  The following sensitive credential file(s) are staged:     ║"
  echo "║                                                              ║"
  for f in "${FOUND[@]}"; do
    printf "║    ✗  %-56s║\n" "$f"
  done
  echo "║                                                              ║"
  echo "║  These files must NEVER be committed to version control.    ║"
  echo "║  Committing them would expose signing keys or Firebase      ║"
  echo "║  credentials that cannot be rotated without consequences.   ║"
  echo "║                                                              ║"
  echo "║  To fix:                                                     ║"
  echo "║    git reset HEAD <file>   — unstage the file               ║"
  echo "║    git rm --cached <file>  — stop tracking a tracked file   ║"
  echo "║                                                              ║"
  echo "║  Store these files in a password manager or CI/CD secrets   ║"
  echo "║  vault (e.g. 1Password, Bitwarden). See CAPACITOR_NOTES.md  ║"
  echo "║  for full security guidance.                                 ║"
  echo "║                                                              ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

# Chain to the existing migration-validation pre-commit check.
REPO_ROOT="$(git rev-parse --show-toplevel)"
MIGRATION_HOOK="$REPO_ROOT/scripts/hooks/pre-commit"
if [[ -x "$MIGRATION_HOOK" ]]; then
  "$MIGRATION_HOOK"
fi
